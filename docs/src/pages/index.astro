<script is:inline>
(function () {
  // Inject data-anim + stagger delays onto repeated elements
  var staggerGroups = [
    ['.dlz-stakeholder-col', 150],
    ['.dlz-finops-item',     150],
    ['.dlz-feature-item',    100],
  ];
  staggerGroups.forEach(function (g) {
    document.querySelectorAll(g[0]).forEach(function (el, i) {
      el.setAttribute('data-anim', '');
      el.dataset.delay = String(i * g[1]);
    });
  });

  // Scroll-reveal via IntersectionObserver
  var io;
  if ('IntersectionObserver' in window) {
    io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        var el = e.target;
        var d = parseInt(el.dataset.delay || '0', 10);
        if (d) {
          setTimeout(function () { el.classList.add('in-view'); }, d);
        } else {
          el.classList.add('in-view');
        }
        io.unobserve(el);
      });
    }, { threshold: 0.1, rootMargin: '-40px 0px' });

    document.querySelectorAll('[data-anim]').forEach(function (el) {
      io.observe(el);
    });
  } else {
    document.querySelectorAll('[data-anim]').forEach(function (el) {
      el.classList.add('in-view');
    });
  }

  // Typing animation for elements with data-typing (skip if user prefers reduced motion)
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll('[data-typing]').forEach(function (el) {
    if (reducedMotion) { el.style.opacity = '1'; return; }
    var full = el.textContent.trim();
    el.textContent = '';
    var cursor = document.createElement('span');
    cursor.className = 'dlz-cursor';
    cursor.setAttribute('aria-hidden', 'true');
    el.appendChild(cursor);

    var started = false;
    var ioT = new IntersectionObserver(function (entries) {
      if (!entries[0].isIntersecting || started) return;
      started = true;
      ioT.disconnect();
      el.style.opacity = '1';
      var i = 0;
      var interval = setInterval(function () {
        el.insertBefore(document.createTextNode(full[i]), cursor);
        i++;
        if (i >= full.length) {
          clearInterval(interval);
          setTimeout(function () {
            cursor.style.animation = 'none';
            cursor.style.opacity = '0';
          }, 1800);
        }
      }, 28);
    }, { threshold: 0.5 });
    ioT.observe(el);
  });
})();
</script>

